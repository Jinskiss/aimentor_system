# ==============================================
# AI 问答服务配置文件
# 复制此文件为 .env 后修改对应值即可
# ==============================================

# ---- 基础配置 ----
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# ---- AI 提供者 ----
# 可选值：
#   groq          - GroqCloud（云端免费，推荐！无需安装任何软件，注册即可用）
#   ollama        - 本地 Ollama（免费，需要本地安装 https://ollama.com）
#   ollama_cloud  - 第三方托管 Ollama API
PROVIDER=groq

# ==============================================
# 方式一：GroqCloud（推荐！免费，无需安装，直接用）
# 注册地址：https://console.groq.com/keys
# 注册后点击 "Create API Key" 即可
# 免费 Tier：DeepSeek-R1-Distill-Qwen-7B 完全免费，无限用量
# ==============================================
GROQ_API_KEY=your_groq_api_key_here
# 推荐模型（均完全免费）：
#   deepseek-r1-distill-qwen-7b  - 推荐！性价比高，数学/代码能力强
#   llama-3.3-70b-versatile      - 速度快，上下文长
#   mixtral-8x7b-32768           - 老牌模型，稳定
GROQ_MODEL=deepseek-r1-distill-qwen-7b

# ==============================================
# 方式二：本地 Ollama（免费，需要先安装 Ollama）
# 安装地址：https://ollama.com
# 安装后运行：ollama pull llama3.2（首次约 2-4GB）
# 启动命令：ollama serve（默认监听 localhost:11434）
# 如用 Ollama，改为：PROVIDER=ollama
# ==============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# ==============================================
# 方式三：Ollama Cloud 第三方托管
# 如用 OllamaCloud，改为：PROVIDER=ollama_cloud
# ==============================================
OLLAMA_CLOUD_BASE_URL=https://your-ollama-cloud-endpoint.com
OLLAMA_CLOUD_MODEL=deepseek-r1

# ---- 对话历史配置 ----
# 最多保存多少轮对话（1 对话 = 1 用户问题 + 1 AI 回答）
MAX_HISTORY=20

# ---- 系统提示词（可选）----
# SYSTEM_PROMPT=你是一位耐心、专业的 AI 学习助手...
