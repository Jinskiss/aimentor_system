HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# 使用本地 Ollama（免费，已安装）
PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# 不使用 Groq
GROQ_API_KEY=
GROQ_MODEL=deepseek-r1-distill-qwen-7b

# 不使用 Ollama Cloud
OLLAMA_CLOUD_BASE_URL=
OLLAMA_CLOUD_MODEL=deepseek-r1

MAX_HISTORY=20
